@model FraudSys.Application.DTOs.PixTransactionRequest
@{ ViewData["Title"] = "Validar Transação PIX"; }

<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card mb-4">
      <div class="card-header py-3">
        <h5 class="mb-0">Validar transação PIX</h5>
      </div>
      <div class="card-body p-4">
        <form asp-action="Validate" method="post">
          <div class="mb-3">
            <label asp-for="Agency" class="form-label fw-medium">Agência</label>
            <input asp-for="Agency" class="form-control" placeholder="Somente números. Ex: 0001" />
            <span asp-validation-for="Agency" class="text-danger small"></span>
          </div>
          <div class="mb-3">
            <label asp-for="AccountNumber" class="form-label fw-medium">Conta</label>
            <input asp-for="AccountNumber" class="form-control" placeholder="Somente números. Ex: 1234567" />
            <span asp-validation-for="AccountNumber" class="text-danger small"></span>
          </div>
          <div class="mb-4">
            <label asp-for="Amount" class="form-label fw-medium">Valor do PIX (R$)</label>
            <input asp-for="Amount" class="form-control form-control-lg" type="number" step="0.01" min="0.01" max="999999.99" placeholder="Ex: 300.00" />
            <span asp-validation-for="Amount" class="text-danger small"></span>
            <div class="form-text">O valor deve ser entre R$ 0,01 e R$ 999.999,99.</div>
          </div>
          <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>
          <button type="submit" class="btn btn-dark w-100 py-2">Validar transação</button>
        </form>
      </div>
    </div>

    @if (ViewBag.Result != null)
    {
      var result = (FraudSys.Application.DTOs.PixTransactionResponse)ViewBag.Result;
      <div class="card border-@(result.Approved ? "success" : "danger")">
        <div class="card-body p-4 text-center">
          <div class="fs-1 mb-2">@(result.Approved ? "✅" : "❌")</div>
          <h5 class="fw-semibold @(result.Approved ? "text-success" : "text-danger")">
            @(result.Approved ? "Transação aprovada!" : "Transação negada")
          </h5>
          <p class="text-muted mb-2">@result.Message</p>
          <div class="mt-3 p-3 bg-light rounded">
            <small class="text-muted d-block">Limite restante</small>
            <span class="fs-4 fw-semibold">
              @result.CurrentLimit.ToString("C", new System.Globalization.CultureInfo("pt-BR"))
            </span>
          </div>
        </div>
      </div>
    }
  </div>
</div>