@model FraudSys.Application.DTOs.UpdateLimitRequest
@{ ViewData["Title"] = "Editar Limite"; }

<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card">
      <div class="card-header py-3">
        <h5 class="mb-0">Atualizar limite PIX</h5>
      </div>
      <div class="card-body p-4">
        <form asp-action="Edit" asp-route-agency="@Context.Request.Query["agency"]" asp-route-accountNumber="@Context.Request.Query["accountNumber"]" method="post">
          <div class="mb-2">
            <label asp-for="PixLimit" class="form-label fw-medium">Novo limite PIX (R$)</label>
            <input asp-for="PixLimit" class="form-control form-control-lg" type="number" step="0.01" min="0.01" max="999999.99" placeholder="Ex: 8000.00" />
            <span asp-validation-for="PixLimit" class="text-danger small"></span>
            <div class="form-text">O valor deve ser entre R$ 0,01 e R$ 999.999,99.</div>
          </div>
          <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>
          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-dark px-4">Salvar</button>
            <a href="javascript:history.back()" class="btn btn-outline-secondary">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>