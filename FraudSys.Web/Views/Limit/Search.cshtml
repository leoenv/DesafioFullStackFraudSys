@{ ViewData["Title"] = "Consultar Conta"; }

<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card">
      <div class="card-header py-3">
        <h5 class="mb-0">Consultar conta</h5>
      </div>
      <div class="card-body p-4">
        <form method="get" action="/Limit/Details">
          <div class="mb-3">
            <label class="form-label fw-medium">Agência</label>
            <input name="agency" class="form-control" placeholder="Somente números. Ex: 0001" required maxlength="10" data-only-numbers="true" />
            <div class="form-text">Digite apenas números.</div>
          </div>
          <div class="mb-4">
            <label class="form-label fw-medium">Conta</label>
            <input name="accountNumber" class="form-control" placeholder="Somente números. Ex: 1234567" required maxlength="15" data-only-numbers="true" />
            <div class="form-text">Digite apenas números.</div>
          </div>
          <button type="submit" class="btn btn-dark w-100 py-2">Consultar</button>
        </form>
      </div>
    </div>
  </div>
</div>