@model FraudSys.Application.DTOs.CreateLimitRequest
@{ ViewData["Title"] = "Cadastrar Limite PIX"; }

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header py-3">
        <h5 class="mb-0">Cadastrar limite PIX</h5>
      </div>
      <div class="card-body p-4">
        <form asp-action="Create" method="post">
          <div class="mb-3">
            <label asp-for="Document" class="form-label fw-medium">CPF</label>
            <input asp-for="Document" class="form-control" placeholder="Somente números (11 dígitos)" maxlength="11" data-only-numbers="true" />
            <span asp-validation-for="Document" class="text-danger small"></span>
          </div>
          <div class="mb-3">
            <label asp-for="Agency" class="form-label fw-medium">Agência</label>
            <input asp-for="Agency" class="form-control" placeholder="Somente números. Ex: 0001" maxlength="10" data-only-numbers="true" />
            <span asp-validation-for="Agency" class="text-danger small"></span>
          </div>
          <div class="mb-3">
            <label asp-for="AccountNumber" class="form-label fw-medium">Conta</label>
            <input asp-for="AccountNumber" class="form-control" placeholder="Somente números. Ex: 1234567" maxlength="15" data-only-numbers="true" />
            <span asp-validation-for="AccountNumber" class="text-danger small"></span>
          </div>
          <div class="mb-4">
            <label asp-for="PixLimit" class="form-label fw-medium">Limite PIX (R$)</label>
            <input asp-for="PixLimit" class="form-control" type="number" step="0.01" min="0.01" max="999999.99" placeholder="Ex: 5000.00" />
            <span asp-validation-for="PixLimit" class="text-danger small"></span>
          </div>
          <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-dark px-4">Cadastrar</button>
            <a href="/" class="btn btn-outline-secondary">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>